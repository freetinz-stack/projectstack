# Copy this file to .env.local for local development
# Never commit .env.local or any file containing real API keys

# ── Lemon Squeezy ─────────────────────────────────────────────────────────────
# Get from: https://app.lemonsqueezy.com/settings/api
LEMON_SQUEEZY_API_KEY=your_lemon_squeezy_api_key_here

# ── Lemon Squeezy Webhook (Phase 4) ──────────────────────────────────────────
# Generate in: Lemon Squeezy → Settings → Webhooks → (your webhook) → Signing secret
# Used by api/webhook.js to verify that events genuinely come from Lemon Squeezy.
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret_here

# ── Firebase Admin SDK (Phase 2 — session cookie) ─────────────────────────────
# Get from: Firebase Console → Project Settings → Service accounts → Generate new private key
# The downloaded JSON contains all three values below.
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
# Paste the private_key value exactly as it appears in the JSON (with literal \n characters).
# Vercel stores it as-is; api/session.js replaces \n with real newlines at runtime.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
